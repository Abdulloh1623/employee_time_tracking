# Backend environment variables (copy to backend/.env or export before running)
DB_URL=jdbc:postgresql://localhost:5432/timegate
DB_USER=timegate
DB_PASSWORD=timegate

# JWT signing secret (use a long random string in production, >= 32 chars)
JWT_SECRET=change-me-please-this-is-a-dev-only-secret-key-256bits-min

# Allowed CORS origins for the web app (comma-separated)
CORS_ORIGINS=http://localhost:5173
